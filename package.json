{
  "name": "opencode-recursive-context",
  "version": "0.1.0",
  "description": "High-assurance read-only recursive context tools for OpenCode.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "packageManager": "npm@11.13.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.mjs",
    "pack:check": "npm pack --dry-run --cache .cache/npm",
    "verify": "npm run typecheck && npm test && npm run pack:check",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "src",
    "docs",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "recursive-context",
    "rlm",
    "context",
    "read-only",
    "code-review",
    "fingerprint"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tah10n/opencode-recursive-context.git"
  },
  "bugs": {
    "url": "https://github.com/Tah10n/opencode-recursive-context/issues"
  },
  "homepage": "https://github.com/Tah10n/opencode-recursive-context#readme",
  "dependencies": {
    "@opencode-ai/plugin": "1.17.7"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "typescript": "5.8.2"
  }
}
